{
	"name": "blueprint-ftc",
	"private": true,
	"version": "1.2.41",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"p": "vite preview",
		"deploy": "npm version patch --no-git-tag-version && echo \"✅ (v$(node -p \"require('./package.json').version\")) deployment successful\"",
		"deploylater": "node scripts/deploy-later.js",
		"deploylater:cancel": "node scripts/deploy-later.js cancel",
		"deploylater:status": "node scripts/deploy-later.js status",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/adapter-vercel": "^6.3.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^25.5.2",
		"@types/three": "^0.183.1",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"rehype-katex": "^4.0.0",
		"remark-math": "^3.0.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"dompurify": "^3.3.3",
		"katex": "^0.16.45",
		"lucide-svelte": "^1.0.1",
		"marked": "^17.0.5",
		"marked-katex-extension": "^5.1.7",
		"svelte-5-french-toast": "^2.0.6",
		"three": "^0.183.2"
	}
}
